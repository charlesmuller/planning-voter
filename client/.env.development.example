# URLs da API e WebSocket para desenvolvimento
REACT_APP_API_URL=http://localhost:4000/api
REACT_APP_SOCKET_URL=http://localhost:4000
REACT_APP_URL_LOCAL=http://localhost:3001

# Ambiente
NODE_ENV=development
PORT=3001

# Google reCAPTCHA (obtenha em https://www.google.com/recaptcha/admin)
# Use a SITE KEY (pública) aqui
# Para desenvolvimento local, deixe em branco se não tiver uma chave
REACT_APP_RECAPTCHA_SITE_KEY=
